rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow everyone to read the 'hello/world' testing doc (optional)
    match /hello/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // must be logged-in
    }

    // Default rule: login required for everything else
    match /{document=**} {
      allow read, write: if request.auth != null;